@model IEnumerable<StudentManagementSystem.Models.Student>

@{
ViewData["Title"] = "Students List";
}

<h2>Students List</h2>
<h2>Students List</h2>

<p style="color:red">
    Current Page = @ViewBag.CurrentPage <br />
    Total Pages = @ViewBag.TotalPages
</p>

<p>
    <a asp-action="Create" class="btn btn-primary">
        Add Student
    </a>
</p>

<form asp-action="Index" method="get" class="mb-3">
    <div class="row">


    <div class="col-md-4">
        <input type="text"
               name="searchString"
               value="@Context.Request.Query["searchString"]"
               class="form-control"
               placeholder="Search Student..." />
    </div>

    <div class="col-md-2">
        <button type="submit"
                class="btn btn-primary">
            Search
        </button>
    </div>

</div>
```

</form>

<table class="table table-bordered table-striped">

```
<thead>
    <tr>

        <th>
            <a asp-action="Index"
               asp-route-sortOrder="@ViewBag.NameSort">
                Name
            </a>
        </th>

        <th>
            <a asp-action="Index"
               asp-route-sortOrder="@ViewBag.EmailSort">
                Email
            </a>
        </th>

        <th>Phone</th>

        <th>
            <a asp-action="Index"
               asp-route-sortOrder="@ViewBag.CourseSort">
                Course
            </a>
        </th>

        <th>Address</th>
        <th>DOB</th>
        <th>Actions</th>

    </tr>
</thead>

<tbody>

    @foreach (var student in Model)
    {
        <tr>

            <td>@student.Name</td>
            <td>@student.Email</td>
            <td>@student.Phone</td>
            <td>@student.Course</td>
            <td>@student.Address</td>
            <td>@student.DOB.ToShortDateString()</td>

            <td>
                <a asp-action="Edit"
                   asp-route-id="@student.Id"
                   class="btn btn-warning btn-sm">
                    Edit
                </a>

                <a asp-action="Delete"
                   asp-route-id="@student.Id"
                   class="btn btn-danger btn-sm">
                    Delete
                </a>
            </td>

        </tr>
    }

</tbody>
```

</table>

<div class="mt-3">

```
@if (ViewBag.CurrentPage > 1)
{
    <a asp-action="Index"
       asp-route-page="@(ViewBag.CurrentPage - 1)"
       class="btn btn-secondary">
        Previous
    </a>
}

<span class="mx-3 fw-bold">
    Page @ViewBag.CurrentPage of @ViewBag.TotalPages
</span>

@if (ViewBag.CurrentPage < ViewBag.TotalPages)
{
    <a asp-action="Index"
       asp-route-page="@(ViewBag.CurrentPage + 1)"
       class="btn btn-primary">
        Next
    </a>
}

</div>
